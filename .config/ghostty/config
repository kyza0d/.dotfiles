adjust-underline-position = 8
adjust-underline-thickness = 0

adjust-cursor-height = 4
adjust-cursor-thickness = 0

adjust-box-thickness = 0

mouse-scroll-multiplier = 1

gtk-wide-tabs = false
gtk-custom-css = style.css

resize-overlay-position = bottom-left
gtk-tabs-location = bottom

keybind = clear

keybind = alt+ctrl+comma=reload_config
keybind = alt+period=text:nvim\n

window-inherit-working-directory = true

keybind = alt+ctrl+o=new_tab

keybind = alt+ctrl+l=next_tab
keybind = alt+ctrl+h=previous_tab

keybind = alt+ctrl+l=next_tab
keybind = alt+ctrl+h=previous_tab

keybind = ctrl+alt+k=scroll_page_lines:-1
keybind = ctrl+alt+j=scroll_page_lines:1

keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard

keybind = alt+ctrl+d=close_surface

confirm-close-surface = false

keybind = alt+ctrl+i=inspector:toggle
keybind = shift+enter=text:\n
